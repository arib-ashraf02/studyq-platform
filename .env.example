# ============================================
# StudyQ — Production Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit your actual .env to GitHub

# ── DATABASE (Neon PostgreSQL) ──────────────
# Get these from https://console.neon.tech
# Connection pooling URL (used for queries — pgbouncer)
DATABASE_URL="postgresql://user:pass@ep-xxx.pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"
# Direct URL (used for migrations — bypasses pgbouncer)
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ── NEXTAUTH ────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars"
# Your deployed Vercel URL (set AFTER first deploy)
NEXTAUTH_URL="https://your-project.vercel.app"

# ── GOOGLE OAUTH ─────────────────────────────
# Get from https://console.cloud.google.com/apis/credentials
# Add your Vercel URL to Authorized redirect URIs:
# https://your-project.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
